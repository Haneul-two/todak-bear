{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "토닥곰",
  "version": "0.1.0",
  "identifier": "com.todak.bear",
  "build": {
    "beforeBuildCommand": "node build-dist.js",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "todak",
        "title": "토닥곰",
        "width": 300,
        "height": 320,
        "x": 1600,
        "y": 720,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
